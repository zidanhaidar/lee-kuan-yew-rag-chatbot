# ---------------------------------------------------------------------------
# LKY RAG Chatbot — environment configuration
# Copy to `.env.local` and fill in. Every var has a sensible default so the
# retrieval pipeline runs with NO keys at all (local hashing embedder).
# A key is only required for the *generation* step (the LLM reply).
# ---------------------------------------------------------------------------

# --- Generation (the LLM that speaks as LKY) -------------------------------
# Pick ONE backend. The app auto-detects which key is present.
#
# Option A — Google AI Studio (Gemini). Free key at https://aistudio.google.com/apikey
#   When this is set, CHAT_MODEL should be a Gemini id (default: gemini-2.5-flash).
GOOGLE_GENERATIVE_AI_API_KEY=
#
# Option B — Vercel AI Gateway. One key routes to many providers (Claude, etc.).
#   Get one at https://vercel.com/ai-gateway. Used only if the Google key is unset.
AI_GATEWAY_API_KEY=

# Chat model. For Google use a Gemini id (e.g. gemini-2.5-flash); for the
# Gateway use a "provider/model" string (e.g. anthropic/claude-sonnet-4-6).
CHAT_MODEL=gemini-2.5-flash

# --- Embeddings (retrieval) ------------------------------------------------
# "local"   -> deterministic hashing embedder, zero dependencies/keys (default)
# "gateway" -> real embeddings via the AI Gateway (recommended for quality)
EMBEDDING_PROVIDER=local

# Embedding model used when EMBEDDING_PROVIDER=gateway
EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Retrieval tuning ------------------------------------------------------
RETRIEVAL_TOP_K=6
CHUNK_SIZE=900
CHUNK_OVERLAP=150
